PORT=3000
NODE_ENV=production

# Public URLs
# - PUBLIC_BASE_URL  : domaine où vivent /preview/* + /admin/{slug} + /api/*
# - ADMIN_BASE_URL   : domaine de l'admin agence (= toi)
# - LANDING_BASE_URL : domaine commercial / landing (peut être == PUBLIC_BASE_URL)
PUBLIC_BASE_URL=https://maquickpage.fr
ADMIN_BASE_URL=https://outil.maquickpage.fr
LANDING_BASE_URL=https://maquickpage.fr

# Falkenstein (custom hostnames coiffeurs + fallback wildcard)
FALKENSTEIN_BASE_URL=https://customers.monsitehq.com
FALLBACK_INTERNAL_HOSTNAME=customers.monsitehq.com

# Admin auth (CHANGE THESE IN PRODUCTION)
ADMIN_EMAIL=admin@lamidetlm.com
ADMIN_PASSWORD_HASH=

# Session secret (random string >= 32 chars)
SESSION_SECRET=

# SQLite path (persistent volume on Coolify)
DB_PATH=/data/salons.db

# Screenshots + uploads directories (persistent volume on Coolify)
SCREENSHOTS_DIR=/data/screenshots

# Internal screenshot URL (Puppeteer fetches this — local to container)
INTERNAL_SCREENSHOT_BASE_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
# Une fois maquickpage.fr vérifié dans Resend, switcher vers noreply@maquickpage.fr
RESEND_FROM_EMAIL=noreply@maquickpage.fr

# Stripe (LIVE mode pour la prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OVH (registration auto .fr/.com via signup flow + admin agence)
OVH_ENDPOINT=https://eu.api.ovh.com/1.0
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=

# Tenant mode (Falkenstein VPS only — désactive admin agence + signup)
TENANT_ONLY=
