PORT=3000
NODE_ENV=production

# Public URLs
PUBLIC_BASE_URL=https://coiffure.lamidetlm.com
ADMIN_BASE_URL=https://outil-coiffure.lamidetlm.com

# Admin auth (CHANGE THESE IN PRODUCTION)
ADMIN_EMAIL=admin@lamidetlm.com
ADMIN_PASSWORD_HASH=

# Session secret (random string)
SESSION_SECRET=

# SQLite path (persistent volume on Coolify)
DB_PATH=/data/salons.db

# Screenshots directory (persistent volume on Coolify)
SCREENSHOTS_DIR=/data/screenshots

# Internal screenshot URL (Puppeteer fetches this — local to container)
INTERNAL_SCREENSHOT_BASE_URL=http://localhost:3000
